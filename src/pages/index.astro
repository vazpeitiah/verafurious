---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Los 5 Furiosos.">
  <div class="navbar bg-base-100 mx-auto max-w-4xl">
    <a class="btn btn-ghost text-xl" href="/">5 Furiosos</a>
  </div>
  <div>
    <ul class="timeline timeline-vertical" id="weeks"></ul>
  </div>
</Layout>

<script>
  import clsx from "clsx";
  import { addWeeks, startOfWeek, addMonths, subDays, subWeeks } from "date-fns";

  const fourious = [
    {
      name: "Vladimir Azpeitia",
      ordinal: 1,
    },
    {
      name: "Luis Rodriguez",
      ordinal: 2,
    },
    {
      name: "Nestor Valencia",
      ordinal: 3,
    },
    {
      name: "Raul Medina",
      ordinal: 4,
    },
    {
      name: "Jair Bautista",
      ordinal: 6,
    },
    {
      name: "Fransico Salgado",
      ordinal: 5,
    },
  ];

  let startDate = startOfWeek(new Date("2024-09-23"));
  const endDate = addMonths(new Date(), 1);

  const weeks = [];

	let fouriousIndex = 0;
  while (startDate < endDate) {
    weeks.push({
      start: startDate,
      end: subDays(addWeeks(startDate, 1), 1),
			assigned: fourious[fouriousIndex % fourious.length],
    });
    startDate = addWeeks(startDate, 1);
		fouriousIndex++;
  }

  fourious.sort((a, b) => a.ordinal - b.ordinal);

  const dateIsBetween = (date: Date, start: Date, end: Date) => {
    return date >= start && date <= end;
  };

  const filteredWeeks = weeks.filter(
    (week) => week.start >= startOfWeek(subWeeks(new Date(), 1))
  );

  const weeksElement = document.getElementById("weeks") as HTMLUListElement;

  weeksElement.innerHTML = filteredWeeks
    .map((week, index) => {
      return `
			<li>
				<div
					class="${clsx("timeline-box timeline-start", {
            ["timeline-end"]: index % 2 !== 0,
            ["bg-primary/40"]: dateIsBetween(new Date(), week.start, week.end),
          })}"
				>
					<h1 class="font-black">
						${week.assigned?.name}
					</h1>
					<p class="text-base">${`${week.start.toLocaleDateString("es-MX")} - ${week.end.toLocaleDateString("es-MX")}`}</p>
				</div>
				<div class="timeline-middle">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 20 20"
						fill="currentColor"
						class="${clsx(
              "h-5 w-5",
              dateIsBetween(new Date(), week.start, week.end)
                ? "text-primary"
                : "text-base-content"
            )}"
					>
						<path
							fill-rule="evenodd"
							d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
							clip-rule="evenodd"
						/>
					</svg>
				</div>
				<hr
					class="${clsx(
            dateIsBetween(new Date(), week.start, week.end) ? "bg-primary" : ""
          )}"
				/>
			</li>
		`;
    })
    .join("");
</script>
